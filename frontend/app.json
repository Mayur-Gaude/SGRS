{
  "expo": {
    "name": "Sgrss",
    "slug": "Sgrss",
    "version": "1.0.0",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sgrss",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow SGRSS to use your location to auto-fill complaint location and route your grievance."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.mayank1007gshshs.sgrss"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SGRSS to use your location to auto-fill complaint location and route your grievance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SGRSS to access your photos for complaint evidence.",
          "cameraPermission": "Allow SGRSS to use your camera to capture complaint evidence."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://sgrs-w6tg.onrender.com",
      "router": {},
      "eas": {
        "projectId": "5dd07146-f794-4782-aea7-9604b9d6b3a4"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
